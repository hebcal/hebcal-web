{
  "name": "hebcal-web",
  "version": "3.8.4",
  "description": "Hebcal server-side Node.js for www.hebcal.com and download.hebcal.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hebcal/hebcal-web.git"
  },
  "bugs": {
    "url": "https://github.com/hebcal/hebcal-web/issues"
  },
  "homepage": "https://github.com/hebcal/hebcal-web#readme",
  "config": {
    "sprite": "sprite14.svg",
    "csprite": "color-icons4.svg",
    "mainCss": "style-5.3.8k.css",
    "holidayFcApp": "fc-6.1.21a.min.js",
    "clientapp": "hebcal-app-5.2.2.min.js"
  },
  "type": "module",
  "engines": {
    "node": ">= 22.5"
  },
  "files": [],
  "scripts": {
    "dev": "node src/app-www.js",
    "dev:download": "NODE_PORT=8081 node src/app-download.js",
    "po2json": "node ./po2json.js po/en.po po/he.po po/pt.po po/es.po po/fr.po po/nl.po po/ashkenazi.po",
    "build": "npm run po2json && npm run css-compile && npm run css-rename && npx rollup -c",
    "deploy": "./deploy.sh",
    "start": "node src/app-www.js",
    "protoc": "protoc --proto_path=src --js_out=import_style=commonjs,binary:src src/download.proto && mv src/download_pb.js src/download_pb.cjs",
    "css-compile": "sass --style compressed --no-source-map --no-error-css --load-path=node_modules --load-path=views/partials scss/:css/ && postcss css/*.css --dir css/ --no-map",
    "css-rename": "mv css/style.css static/i/$npm_package_config_mainCss",
    "pretest": "touch hebcal-dot-com.ini",
    "lint": "oxlint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "hebcal"
  ],
  "author": "Michael J. Radwin (https://github.com/mjradwin)",
  "license": "BSD-2-Clause",
  "allowScripts": {
    "murmurhash3": true
  },
  "devDependencies": {
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@popperjs/core": "^2.11.8",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "bootstrap": "^5.3.8",
    "bootstrap5-autocomplete": "^1.1.42",
    "critical": "^8.0.0",
    "csv-parse": "^7.0.1",
    "gettext-parser": "^9.1.1",
    "oxlint": "^1.74.0",
    "papaparse": "^5.5.4",
    "postcss": "^8.5.19",
    "postcss-cli": "^11.0.1",
    "rollup": "^4.62.2",
    "sass": "^1.101.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@hebcal/core": "^6.6.0",
    "@hebcal/geo-sqlite": "^5.12.0",
    "@hebcal/hdate": "^0.22.5",
    "@hebcal/icalendar": "^6.3.8",
    "@hebcal/learning": "^6.9.5",
    "@hebcal/leyning": "^9.5.5",
    "@hebcal/locales": "^6.5.1",
    "@hebcal/rest-api": "^6.5.1",
    "@hebcal/triennial": "^6.3.0",
    "@koa/ejs": "^5.1.0",
    "@koa/send": "^6.0.0",
    "dayjs": "^1.11.21",
    "ejs": "^6.0.1",
    "fastest-levenshtein": "^1.0.16",
    "geo-tz": "^8.1.8",
    "google-protobuf": "^4.0.2",
    "haversine": "^1.1.1",
    "http-errors": "^2.0.1",
    "ini": "^7.0.0",
    "koa": "^3.2.1",
    "koa-better-response-time": "^1.3.0",
    "koa-bodyparser": "^4.4.1",
    "koa-compress": "^5.2.2",
    "koa-conditional-get": "^3.0.0",
    "koa-error": "^3.2.0",
    "koa-static": "^5.0.0",
    "koa-timeout-v2": "^1.0.0",
    "minimist": "^1.2.8",
    "murmurhash3": "^0.5.0",
    "mysql2": "^3.23.0",
    "nodemailer": "^9.0.3",
    "nodemailer-html-to-text": "^3.2.0",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "probe-image-size": "^7.3.0",
    "prom-client": "^15.1.3",
    "quick-lru": "^7.3.0",
    "random-bigint": "0.0.1",
    "simpledotcss": "^2.3.7",
    "transliteration": "^2.6.1",
    "ulid": "^3.0.2"
  }
}
